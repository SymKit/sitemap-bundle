{% extends '@WebProfiler/Profiler/layout.html.twig' %}
{% trans_default_domain 'SymkitSitemapBundle' %}

{% block toolbar %}
    {% set icon %}
        {{ include('@WebProfiler/Icon/redirect.svg') }}
        <span class="sf-toolbar-value">{{ collector.totalUrls }}</span>
        <span class="sf-toolbar-label">{% trans %}profiler.toolbar_label{% endtrans %}</span>
    {% endset %}

    {% set text %}
        <div class="sf-toolbar-info-piece">
            <b>{% trans %}profiler.loaders{% endtrans %}</b>
            <span>{{ collector.loaders|length }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>{% trans %}profiler.total_urls{% endtrans %}</b>
            <span>{{ collector.totalUrls }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>{% trans %}profiler.cache{% endtrans %}</b>
            <span>{{ collector.cacheEnabled ? 'profiler.cache_value_enabled'|trans : 'profiler.cache_value_disabled'|trans }}</span>
        </div>
    {% endset %}

    {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: profiler_url }) }}
{% endblock %}

{% block menu %}
    <span class="label">
        <span class="icon">{{ include('@WebProfiler/Icon/redirect.svg') }}</span>
        <strong>{% trans %}profiler.sitemap{% endtrans %}</strong>
        <span class="count">
            <span>{{ collector.totalUrls }}</span>
        </span>
    </span>
{% endblock %}

{% block panel %}
    <h2>{% trans %}profiler.sitemap{% endtrans %}</h2>

    <div class="metrics">
        <div class="metric">
            <span class="value">{{ collector.loaders|length }}</span>
            <span class="label">{% trans %}profiler.loaders{% endtrans %}</span>
        </div>
        <div class="metric">
            <span class="value">{{ collector.totalUrls }}</span>
            <span class="label">{% trans %}profiler.total_urls{% endtrans %}</span>
        </div>
        <div class="metric">
            <span class="value">{{ collector.cacheEnabled ? 'profiler.cache_yes'|trans : 'profiler.cache_no'|trans }}</span>
            <span class="label">{% trans %}profiler.cache_enabled{% endtrans %}</span>
        </div>
    </div>

    <h3>{% trans %}profiler.registered_loaders{% endtrans %}</h3>
    {% if collector.loaders|length %}
        <table>
            <thead>
                <tr>
                    <th>{% trans %}profiler.name{% endtrans %}</th>
                    <th>{% trans %}profiler.class{% endtrans %}</th>
                    <th>{% trans %}profiler.url_count{% endtrans %}</th>
                </tr>
            </thead>
            <tbody>
                {% for name, loader in collector.loaders %}
                    <tr>
                        <td>{{ name }}</td>
                        <td><code>{{ loader.class }}</code></td>
                        <td>{{ loader.count }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="empty">
            <p>{% trans %}profiler.no_loaders{% endtrans %}</p>
        </div>
    {% endif %}

    {% if collector.generations|length %}
        <h3>{% trans %}profiler.generations_title{% endtrans %}</h3>
        <table>
            <thead>
                <tr>
                    <th>{% trans %}profiler.name{% endtrans %}</th>
                    <th>{% trans %}profiler.page{% endtrans %}</th>
                    <th>{% trans %}profiler.duration{% endtrans %}</th>
                    <th>{% trans %}profiler.size{% endtrans %}</th>
                </tr>
            </thead>
            <tbody>
                {% for gen in collector.generations %}
                    <tr>
                        <td>{{ gen.name ?? 'index' }}</td>
                        <td>{{ gen.page }}</td>
                        <td>{{ '%0.2f'|format(gen.duration * 1000) }} ms</td>
                        <td>{{ '%0.1f'|format(gen.size / 1024) }} KB</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
